# 雪峰Agent 环境变量配置模板
# 复制此文件为 .env 并填入实际值：cp .env.example .env
# 优先级：环境变量 > .env > config.json > 默认值
# CloudBase 云托管：在控制台「服务设置 → 环境变量」中配置，无需 .env 文件。

# ─────────────────────────────────────────────
# LLM API（必填）
# ─────────────────────────────────────────────
# DeepSeek API Key（从 platform.deepseek.com 获取）
LLM_API_KEY=
# LLM API 地址（默认 https://api.deepseek.com）
LLM_API_URL=https://api.deepseek.com
# LLM 模型（deepseek-v4-flash / deepseek-v4-pro）
LLM_MODEL=deepseek-v4-flash

# ─────────────────────────────────────────────
# 联网搜索（可选，不填则搜索功能降级）
# ─────────────────────────────────────────────
# Tavily API Key（从 tavily.com 获取）
TAVILY_KEY=

# ─────────────────────────────────────────────
# 微信小程序（生产环境必填）
# ─────────────────────────────────────────────
# 小程序 AppID（从微信公众平台获取）
WX_APPID=
# 小程序 AppSecret（从微信公众平台 → 开发管理 → 开发设置 获取）
WX_SECRET=

# ─────────────────────────────────────────────
# 开发模式（仅本地开发，生产环境不要设置）
# ─────────────────────────────────────────────
# 设置为 1 时允许 dev_user 回退（所有用户共享同一身份）
# XF_ALLOW_DEV=1
